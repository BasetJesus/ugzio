generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
// ─── BILLING ─────────────────────────────────────────────────────────────────

model Plan {
  id                   String         @id @default(cuid())
  name                 String         @unique // free|essentiel|croissance
  maxOrdersPerMonth    Int
  maxUsersPerOrg       Int
  hasZioConfirm        Boolean        @default(false)
  hasZioBrain          Boolean        @default(false)
  hasZioConnect        Boolean        @default(false)
  hasZioFlow           Boolean        @default(false)
  hasZioNetwork        Boolean        @default(false)
  aiInsightsPerMonth   Int            @default(0)
  verificationsPerMonth Int           @default(0)
  price                Float
  currency             String         @default("TND")
  subscriptions        Subscription[]
}

model Subscription {
  id                    String       @id @default(cuid())
  organizationId        String       @unique
  organization          Organization @relation(fields: [organizationId], references: [id])
  planId                String
  plan                  Plan         @relation(fields: [planId], references: [id])
  status                String       // active|past_due|canceled|trialing
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  konnectSubscriptionId String?
  canceledAt            DateTime?
  createdAt             DateTime     @default(now())
}

model UsageMeter {
  id                    String       @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id])
  periodStart           DateTime
  periodEnd             DateTime
  ordersProcessed       Int          @default(0)
  aiInsightsGenerated   Int          @default(0)
  verificationsSent     Int          @default(0)
  aiTokensUsed          Int          @default(0)
  ordersLimit           Int
  aiInsightsLimit       Int
  verificationsLimit    Int
  createdAt             DateTime     @default(now())
}

// ─── FEATURE FLAGS (v3, Sprint 1) ────────────────────────────────────────────

model FeatureFlag {
  id             String   @id @default(cuid())
  key            String   @unique
  enabled        Boolean  @default(false)
  rolloutPercent Int      @default(0)
  planGate       String?
  description    String
  updatedAt      DateTime @updatedAt
}

// ─── ORGANIZATION & USERS ────────────────────────────────────────────────────

model Organization {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  subscription      Subscription?
  usageMeters       UsageMeter[]
  orders            Order[]
  deliveryProviders DeliveryProvider[]
  operationOutcomes OperationOutcome[]
  automationRules   AutomationRule[]
  workflowExecutions WorkflowExecution[]
  conversations     Conversation[]
  members           OrganizationMember[]
  webhookLogs       WebhookLog[]
  aiEvaluations     AIEvaluation[]
  deletionRequests  BuyerDeletionRequest[]
  waitlistEntries   WaitlistEntry[]
  activationEvents  ActivationEvent[]
  maxOrdersPerMonth  Int                @default(3)
  subscriptionStatus String            @default("free")  // free|essentiel|croissance
  ordersThisMonth   Int                @default(0)
  sellerPhone       String?
  sellerName        String?
  brandDescription  String?
  socialLinks       String?            @default("{}")
  whatsappConnection WhatsAppConnection?
  ugcTemplates      UgcRequestTemplate[]
  createdAt         DateTime           @default(now())
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  role           String       // owner|admin|member
  createdAt      DateTime     @default(now())
  @@unique([organizationId, userId])
}

model User {
  id            String               @id @default(cuid())
  email         String               @unique
  name          String?
  password      String?
  image         String?
  memberships   OrganizationMember[]
  createdAt     DateTime             @default(now())
}

// ─── DELIVERY PROVIDERS ──────────────────────────────────────────────────────

model DeliveryProvider {
  id                  String        @id @default(cuid())
  organizationId      String
  organization        Organization  @relation(fields: [organizationId], references: [id])
  name                String
  rtsCostPerFailure   Float         @default(15.0)
  avgDeliveryDays     Int           @default(3)
  contactSuccessRate  Float?
  isDefault           Boolean       @default(false)
  orders              Order[]
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  @@unique([organizationId, name])
}

// ─── OPERATION OUTCOMES (Revenue Protection Tracking) ─────────────────────────

model OperationOutcome {
  id                    String        @id @default(cuid())
  organizationId        String
  organization          Organization  @relation(fields: [organizationId], references: [id])
  orderId               String
  order                 Order         @relation(fields: [orderId], references: [id])
  actionTaken           String        // confirm | cancel | unreachable | suspicious | retry
  estimatedRevenueSaved Float         @default(0)
  estimatedLossPrevented Float        @default(0)
  riskLevelBefore       String?       // low | medium | high
  orderAmount           Float
  trustScoreBefore      Int?
  attemptedBy           String?
  notes                 String?
  createdAt             DateTime      @default(now())

  @@index([organizationId, createdAt])
  @@index([orderId])
}

// ─── ORDERS & BUYERS ─────────────────────────────────────────────────────────

model BuyerIdentity {
  id               String   @id @default(cuid())
  anonymizedId     String   @unique
  riskScore        Float    @default(50)
  networkMlScore   Float    @default(50)
  totalOrders      Int      @default(0)
  failedOrders     Int      @default(0)
  successfulOrders Int      @default(0)
  blacklistedCount Int      @default(0)
  updatedAt        DateTime @updatedAt
}

// Canonical status values:
// CREATED | PRE_SHIPPING_CONFIRM_SENT | BUYER_CONFIRMED | SHIPPED | DELIVERED
// UGC_REQUESTED | UGC_RECEIVED | INTELLIGENT_CANCEL | PENDING_RESCHEDULE | REFUSED
model Order {
  id                 String               @id @default(cuid())
  token              String               @unique @default(uuid())
  organizationId     String
  organization       Organization         @relation(fields: [organizationId], references: [id])
  deliveryProviderId String?
  deliveryProvider   DeliveryProvider?    @relation(fields: [deliveryProviderId], references: [id])
  buyerName          String
  buyerPhone         String
  product            String?
  buyerWilaya        String?
  buyerAddress       String?
  amount             Float
  currency           String               @default("TND")
  riskLevel          String               @default("medium")    // low|medium|high
  trustScore         Int                  @default(50)          // 0-100
  mlScore            Float?
  status             String               @default("CREATED")
  verificationStatus String               @default("none")     // deprecated, use status
  confirmStatus      String               @default("pending_confirmation")
  deletedAt          DateTime?
  createdAt          DateTime             @default(now())
  conversations      Conversation[]
  confirmationAttempts ConfirmationAttempt[]
  outcome            OrderOutcome?
  operationOutcomes  OperationOutcome[]
  workflowExecutions WorkflowExecution[]
  timeline           MessageTimelineEntry[]
  ugcItems           UgcItem[]
}

model MessageTimelineEntry {
  id           String   @id @default(cuid())
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  eventType    String   // anticipation|social_proof|visual_ownership|pre_delivery_confirm|d3_ugc_ask
  scheduledFor DateTime
  sentAt       DateTime?
  status       String   @default("scheduled") // scheduled|sent|failed
  createdAt    DateTime @default(now())
}

model UgcItem {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  mediaUrl   String
  mediaType  String   // image|video
  buyerPhone String
  status     String   @default("received") // received|approved|rejected
  createdAt  DateTime @default(now())
}

model UgcRequestTemplate {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String   // seller-facing label, e.g. "Photo with 15 TND incentive"
  requestType    String   // photo_review|instagram_story|tiktok_unboxing|written_testimonial|whatsapp_feedback
  messageBody    String   // template with {{buyerName}}, {{product}}, {{orderAmount}}, {{incentive}}
  incentive      String   // e.g. "15 TND", "20 TND", "shoutout"
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ─── CONFIRMATION WORKFLOW (v4) ───────────────────────────────────────────────

model ConfirmationAttempt {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id])
  method         String   // manual_call|whatsapp|sms
  outcome        String   // confirmed|unreachable|suspicious|no_answer
  notes          String?
  attemptedBy    String?
  createdAt      DateTime @default(now())
}

// ─── WEBHOOK IDEMPOTENCY (v3) ─────────────────────────────────────────────────

model WebhookLog {
  id              String       @id @default(cuid())
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  provider        String
  eventType       String
  eventId         String       @unique
  payload         String
  signature       String
  processed       Boolean      @default(false)
  receivedAt      DateTime     @default(now())
}

// ─── WORKFLOW AUTOMATION ──────────────────────────────────────────────────────

model AutomationRule {
  id                    String             @id @default(cuid())
  organizationId        String
  organization          Organization       @relation(fields: [organizationId], references: [id])
  name                  String
  enabled               Boolean            @default(true)
  trigger               String
  conditions            String             @default("[]")
  actions               String             @default("[]")
  priority              Int                @default(0)
  maxExecutionsPerHour  Int                @default(10)
  executionCount        Int                @default(0)
  lastTriggeredAt       DateTime?
  createdAt             DateTime           @default(now())
  executions            WorkflowExecution[]
}

model WorkflowExecution {
  id               String         @id @default(cuid())
  automationRuleId String
  automationRule   AutomationRule @relation(fields: [automationRuleId], references: [id])
  organizationId   String
  organization     Organization   @relation(fields: [organizationId], references: [id])
  orderId          String?
  order            Order?         @relation(fields: [orderId], references: [id])
  triggeredBy      String
  eventPayload     String
  conditionsMatched Boolean
  actionsDispatched String
  status           String         @default("queued")
  errorMessage     String?
  executedAt       DateTime       @default(now())
  completedAt      DateTime?
}

// ─── ZIOINBOX ────────────────────────────────────────────────────────────────

model Conversation {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  orderId        String?
  order          Order?       @relation(fields: [orderId], references: [id])
  buyerName      String
  buyerPhone     String
  messages       Message[]
  notes          InternalNote[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  direction      String       // inbound|outbound
  content        String
  channel        String       // whatsapp|sms
  status         String       // sent|delivered|read|failed
  createdAt      DateTime     @default(now())
}

model InternalNote {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  content        String
  authorId       String
  createdAt      DateTime     @default(now())
}

// ─── ORDER OUTCOME ─────────────────────────────────────────────────────────────

model OrderOutcome {
  id             String   @id @default(cuid())
  orderId        String   @unique
  order          Order    @relation(fields: [orderId], references: [id])
  organizationId String
  outcome        String   // DELIVERED|RETURNED|REFUSED|DISPUTED
  labelSource    String   // WEBHOOK|SELLER|INFERRED
  labelWeight    Float    @default(1.0)
  confirmedAt    DateTime @default(now())
}

// ─── OUTCOME INTELLIGENCE (Outcome Attribution) ───────────────────────────────

model ActionOutcomeAttribution {
  id                    String    @id @default(cuid())
  organizationId        String
  orderId               String
  actionId              String    @unique
  actionTaken           String    // confirm|cancel|unreachable|suspicious|retry|NO_ACTION
  sequenceType          String?   // trust|reassurance|urgency|reminder|null (manual)
  sequenceVersion       Int?      // 1 = current generation

  // ── Context snapshots (immutable, captured at action time) ──
  riskScoreSnapshot       Int?     // trustScore at action time
  orderValueSnapshot      Float?   // amount at action time
  buyerOrderCountSnapshot Int?     // BuyerIdentity.totalOrders at action time
  isFirstOrderSnapshot    Boolean? // true if this was buyer's first order
  citySnapshot            String?  // buyerWilaya at action time
  paymentMethodSnapshot   String?  // COD|ONLINE
  confirmationStateSnapshot String? // confirmStatus at action time

  finalDeliveryOutcome  String?   // DELIVERED|REFUSED|RETURNED|PENDING
  daysToOutcome         Int?
  estimatedRevenueSaved Float
  createdAt             DateTime  @default(now())
  resolvedAt            DateTime?

  @@index([organizationId, sequenceType])
  @@index([organizationId, actionTaken])
  @@index([organizationId, finalDeliveryOutcome])
  @@index([organizationId, isFirstOrderSnapshot])
  @@index([organizationId, citySnapshot])
  @@index([organizationId, riskScoreSnapshot])
  @@index([orderId])
}

// ─── AI EVALUATION (v3) ──────────────────────────────────────────────────────

model AIEvaluation {
  id                  String       @id @default(cuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  insightId           String
  recommendationType  String
  wasActedOn          Boolean      @default(false)
  sellerRating        Int?
  outcomeAfter14d     String?
  evaluatedAt         DateTime     @default(now())
}

// ─── BUYER JOURNEY EVENTS (v2) ────────────────────────────────────────────────

model BuyerJourneyEvent {
  id           String   @id @default(cuid())
  organizationId String
  orderId      String
  eventType    String
  metadata     String?  // JSON blob, never queried by value
  createdByUserId String?
  occurredAt   DateTime @default(now())

  @@index([organizationId, orderId])
  @@index([eventType, occurredAt])
  @@index([occurredAt])
}

// ─── OPERATION TIMELINE (v4) ────────────────────────────────────────────────

model OperationEvent {
  id             String   @id @default(cuid())
  organizationId String
  orderId        String
  type           String   // message_sent|whatsapp_opened|buyer_replied|confirmed|unreachable|cancelled|retry_scheduled|operator_note|sequence_selected
  metadata       String?  // JSON blob, never queried by value
  actorType      String   // system|operator|buyer
  createdAt      DateTime @default(now())

  @@index([organizationId, orderId])
  @@index([organizationId, createdAt])
}

// ─── COMPLIANCE (v3) ─────────────────────────────────────────────────────────

model BuyerDeletionRequest {
  id             String       @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  requestedPhone String
  requestedAt    DateTime     @default(now())
  status         String       @default("pending")
  completedAt    DateTime?
  orgsAffected   Int          @default(0)
  requestSource  String       // seller|buyer_self|legal
}

model DataProcessingAgreement {
  id             String   @id @default(cuid())
  organizationId String   @unique
  version        String
  signedAt       DateTime @default(now())
  signedByUserId String
}

// ─── ZIOLAUNCH GROWTH (Sprint 3) ────────────────────────────────────────────

model ActivationEvent {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  eventType      String       // FIRST_ORDER_CREATED|FIRST_TRUST_SCORE|FIRST_VERIFICATION_SENT|FIRST_HIGH_RISK_BLOCKED|FIRST_WORKFLOW_ENABLED
  occurredAt     DateTime     @default(now())
}

model WaitlistEntry {
  id             String        @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  name           String
  email          String
  phone          String?
  niche          String?
  instagram      String?
  storeType      String?
  monthlyOrders  Int?
  biggestProblem String?
  status         String        @default("new")  // new|reviewed|invited|activated
  createdAt      DateTime      @default(now())
}

model Referral {
  id         String   @id @default(cuid())
  referrerId String
  referredId String?
  code       String   @unique
  createdAt  DateTime @default(now())
}

// ─── WHATSAPP OPERATIONAL LAYER (v4) ─────────────────────────────────────────

model WhatsAppConnection {
  id              String       @id @default(cuid())
  organizationId  String       @unique
  organization    Organization @relation(fields: [organizationId], references: [id])
  status          String       // connected|disconnected|pending|expired
  phoneNumber     String?
  phoneNumberId   String?
  accessToken     String?
  connectedAt     DateTime?
  expiresAt       DateTime?
  updatedAt       DateTime     @updatedAt
  createdAt       DateTime     @default(now())
}
